DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# 개발 전용: true 이면 로그인 필수·IP 게이트·이메일 도메인 검사 완화
OPEN_ACCESS_DEV="false"
# ALLOWED_IPS="203.0.113.10,10.0.0.0/24"
# ALLOWED_EMAIL_DOMAINS="company.com,subsidiary.com"
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="Alt 검수 <noreply@company.com>"
# OCR 대상 이미지 상한 (png/jpeg/gif/webp/bmp, SVG 제외)
# MAX_OCR_IMAGES="80"
# 구글 Cloud Vision (텍스트 추출 엔진 «구글 비전» 선택 시)
# GOOGLE_CLOUD_VISION_API_KEY=""
